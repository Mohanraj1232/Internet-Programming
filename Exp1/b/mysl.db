CREATE DATABASE onlineexam;

USE onlineexam;

CREATE TABLE student(
    regno VARCHAR(10) PRIMARY KEY,
    name VARCHAR(50),
    department VARCHAR(30),
    mark1 INT,
    mark2 INT,
    mark3 INT
);

